{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "dist/main",
    "rootDir": "src/main",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["node"]
  },
  "include": ["src/main/**/*.ts"]
}
